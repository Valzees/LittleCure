<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorCardBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Left Circular Icon Container -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/avatar_circle_bg"
            android:backgroundTint="@color/colorPrimaryLight">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/colorPrimary" />
        </FrameLayout>

        <!-- Center Text Information -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryDiagnosis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Annual Wellness Checkup"
                android:textColor="@color/colorTextDark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Dr. Chen • Oct 12, 2023"
                android:textColor="@color/colorTextLight"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvHistoryComplaint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Complaint: -"
                android:textColor="@color/colorTextLight"
                android:textSize="12sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/tvHistoryPrescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Prescription: -"
                android:textColor="@color/colorTextLight"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Right Side: Status Badge and chevron -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvHistoryPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/status_completed_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="Completed"
                android:textColor="@color/status_completed_text"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="→"
                android:textColor="@color/colorTextLight"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/colorCardBg">

        <TextView
            android:id="@+id/tvForgotTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account Recovery"
            android:textColor="@color/colorTextDark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvForgotSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Step 1: Enter your registered email/username."
            android:textColor="@color/colorTextLight"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/colorBorder" />

        <!-- STEP 1 Layout: Check User Existence -->
        <LinearLayout
            android:id="@+id/layoutForgotStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registered Email / Username"
                android:textColor="@color/colorTextDark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etForgotEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edittext_border"
                android:hint="e.g. patient@example.com or patient"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textColor="@color/colorTextDark"
                android:textColorHint="@color/colorTextLight"
                android:textSize="14sp" />

            <!-- Buttons Step 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnForgotCancel"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="@color/colorTextLight" />

                <Button
                    android:id="@+id/btnForgotNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:text="Check Account"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- STEP 2 Layout: Enter New Password (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutForgotStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- New Password Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Password"
                android:textColor="@color/colorTextDark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etForgotNewPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edittext_border"
                android:hint="Enter at least 6 characters"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="@color/colorTextDark"
                android:textColorHint="@color/colorTextLight"
                android:textSize="14sp" />

            <!-- Confirm New Password Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Confirm New Password"
                android:textColor="@color/colorTextDark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etForgotConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edittext_border"
                android:hint="Repeat new password"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="@color/colorTextDark"
                android:textColorHint="@color/colorTextLight"
                android:textSize="14sp" />

            <!-- Buttons Step 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnForgotCancelStep2"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="@color/colorTextLight" />

                <Button
                    android:id="@+id/btnForgotSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:text="Reset Password"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

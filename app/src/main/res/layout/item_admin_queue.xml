<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorCardBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Horizontal Container for Avatar and Patient Details -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/tvAdminQueueStatus">

                <!-- Circular Avatar for Initials -->
                <TextView
                    android:id="@+id/tvAdminQueueAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/avatar_circle_bg"
                    android:gravity="center"
                    android:text="PA"
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Patient details -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAdminQueuePatientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leo Anderson"
                        android:textColor="@color/colorTextDark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminQueuePayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Method: Insurance"
                        android:textColor="@color/colorTextLight"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvAdminQueueStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@color/status_waiting_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pending Verification"
                android:textColor="@color/status_waiting_text"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/colorBorder" />

        <TextView
            android:id="@+id/tvAdminQueueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date: 2026-06-04"
            android:textColor="@color/colorTextDark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvAdminQueueComplaint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Complaint: -"
            android:textColor="@color/colorTextLight"
            android:textSize="13sp" />

        <!-- Doctor diagnosis/prescription info (Only visible for completed exams) -->
        <LinearLayout
            android:id="@+id/layoutAdminMedDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#F8FAFC"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAdminDiagnosis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnosis: -"
                android:textColor="@color/colorTextDark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdminPrescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Prescription: -"
                android:textColor="@color/colorTextDark"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Dynamic Action Row (Verify/Pay & Contact Trigger) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAdminAction"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:backgroundTint="@color/colorPrimary"
                android:text="Verify"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="23dp"
                android:visibility="visible" />

            <ImageButton
                android:id="@+id/btnAdminContact"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/avatar_circle_bg"
                android:backgroundTint="@color/status_completed_bg"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/colorPrimary"
                android:contentDescription="Contact via WhatsApp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
